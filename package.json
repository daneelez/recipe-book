{
  "name": "recipe-book",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -k \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "build": "npm run build --workspace=server && npm run build --workspace=client",
    "test": "npm run test --workspace=server",
    "db:push": "npm run db:push --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
